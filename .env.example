# ──────────────────────────────────────────────
# Configurações da Aplicação
# ──────────────────────────────────────────────
# Copie este arquivo para .env ou .env.local e preencha os valores.
# Nunca versionar .env ou .env.local (contêm segredos).
APP_NAME="VMDK Zombie Scanner"
APP_VERSION="1.0.0"
DEBUG=false

# ──────────────────────────────────────────────
# CORS (FastAPI)
# ──────────────────────────────────────────────
# Origens permitidas para requisições cross-origin (separadas por vírgula).
# Se não definido, fallback seguro: http://localhost:8000
# Exemplo: http://localhost:3000,https://meudominio.com
CORS_ALLOWED_ORIGINS="http://localhost:8000"

# ──────────────────────────────────────────────
# Autenticação (Bearer Token / API Key)
# ──────────────────────────────────────────────
# Segredo para assinar os JWT (gere com: openssl rand -hex 32)
SECRET_KEY="YOUR_VALUE_HERE"
ALGORITHM="HS256"
# Expiração do token em minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API Key estática (alternativa ao JWT)
API_KEY="YOUR_VALUE_HERE"

# ──────────────────────────────────────────────
# Banco de Dados SQLite
# ──────────────────────────────────────────────
DATABASE_URL="sqlite+aiosqlite:///./vmdk_scanner.db"

# ──────────────────────────────────────────────
# vCenters (credenciais por vCenter ficam no BD)
# Use a rota POST /api/v1/vcenters para cadastrar cada instância.
# ──────────────────────────────────────────────
# Exemplo de vCenter padrão (opcional)
DEFAULT_VCENTER_HOST=""
DEFAULT_VCENTER_USER=""
DEFAULT_VCENTER_PASSWORD="YOUR_VALUE_HERE"
DEFAULT_VCENTER_PORT=443
DEFAULT_VCENTER_DISABLE_SSL_VERIFY=true

# ──────────────────────────────────────────────
# Criptografia de senhas (Fernet)
# Gere uma chave válida com:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ──────────────────────────────────────────────
FERNET_KEY="YOUR_VALUE_HERE"

# ──────────────────────────────────────────────
# Connection Pool de vCenters
# ──────────────────────────────────────────────
VCENTER_CONNECT_TIMEOUT_SEC=30
VCENTER_MAX_RETRIES=3
VCENTER_RETRY_BASE_DELAY_SEC=2.0

# ──────────────────────────────────────────────
# Scanner
# ──────────────────────────────────────────────
# Limiar (dias) para considerar um VMDK sem VM associada como "orphaned"
ORPHAN_DAYS=60
ORPHANED_THRESHOLD_DAYS=60
STALE_SNAPSHOT_DAYS=15
MIN_FILE_SIZE_MB=50
SCAN_MAX_WORKERS=4
SCAN_DATASTORE_TIMEOUT_SEC=900

# ──────────────────────────────────────────────
# Agendamento (APScheduler)
# ──────────────────────────────────────────────
# Cron padrão sugerido ao criar novos agendamentos via API.
# Não é aplicado automaticamente — cada ScanSchedule tem sua própria expressão.
# Fuso horário: todos os crons são interpretados em UTC.
# Exemplos:
#   "0 2 * * *"    → todo dia às 02:00 UTC
#   "0 */6 * * *"  → a cada 6 horas
#   "0 8 * * 1"    → toda segunda-feira às 08:00 UTC
SCAN_CRON_DEFAULT="0 2 * * *"

# ──────────────────────────────────────────────
# Interface Web Flask (web/app.py)
# ──────────────────────────────────────────────
FLASK_PORT=5000

# ──────────────────────────────────────────────
# Agendador cron (web/scheduler/cron_runner.py)
# ──────────────────────────────────────────────
SCAN_CRON_HOUR=2
SCAN_CRON_MINUTE=0
PS_SCRIPT_PATH="scripts/ZombieHunter.ps1"
REPORTS_DIR="reports/data"

# ──────────────────────────────────────────────
# Modo Somente-Leitura (READONLY_MODE)
# ──────────────────────────────────────────────
# PADRÃO OBRIGATÓRIO: true
# Esta API NUNCA executa operações destrutivas em VMDKs por padrão.
#
# Para habilitar delete/move/rename de VMDKs é OBRIGATÓRIO:
#   1. Mudar para false (decisão explícita do analista)
#   2. Obter um ApprovalToken via POST /api/v1/approvals
#   3. Incluir X-Approval-Token no header + "confirmed": true no corpo
#
# ⚠️  NÃO mude para false sem plena consciência das consequências.
# ⚠️  Operações destrutivas em VMDKs de produção são IRREVERSÍVEIS.
READONLY_MODE=true
